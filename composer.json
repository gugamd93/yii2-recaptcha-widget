{
    "name": "gugamd93/yii2-recaptcha-widget",
    "description": "Yii2 Google reCAPTCHA v2 and v3 widget compatible with PHP 8.4+",
    "keywords": ["yii2", "captcha", "recaptcha", "google", "widget", "php8.4", "php8.5"],
    "type": "yii2-extension",
    "license": "MIT",
    "support": {
        "source": "https://github.com/gugamd93/yii2-recaptcha-widget",
        "issues": "https://github.com/gugamd93/yii2-recaptcha-widget/issues"
    },
    "authors": [
        {
            "name": "Gustavo",
            "homepage": "https://github.com/gugamd93"
        },
        {
            "name": "HimikLab",
            "homepage": "https://github.com/himiklab/"
        }
    ],
    "require": {
        "php": ">=7.4",
        "yiisoft/yii2": "~2.0.11",
        "yiisoft/yii2-httpclient": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0 || ^10.0"
    },
    "autoload": {
        "psr-4": {
            "himiklab\\yii2\\recaptcha\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "himiklab\\yii2\\recaptcha\\tests\\": "tests/"
        }
    }
}
